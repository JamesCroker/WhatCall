{
  "name": "whatcall",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "nserve serve",
    "emulators:start": "firebase emulators:start --project demo-test --import testdata",
    "emulators:export": "firebase emulators:export --project demo-test testdata",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:karma": "ng test --browsers ChromeHeadless --no-progress --no-watch",
    "test:jest": "firebase emulators:exec --project demo-firestore-rules \"jest --detectOpenHandles\"",
    "doc": "npx typedoc --out docs --entryPointStrategy Expand src  --exclude **/*.spec.ts --excludePrivate --excludeExternals --includeVersion",
    "uml": "tsuml2 --glob \"./src/**/!(*.d|*.spec).ts\" --outFile  ./docs/uml.svg",
    "lint": "npx eslint src",
    "sme": "ng build --configuration=production --source-map=true --named-chunks==true && source-map-explorer dist/whatcall/**/*.js --no-border-checks",
    "e2e": "ng e2e",
    "e2e:ui": "npx playwright test --ui",
    "e2e:report": "npx playwright show-report"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/cdk": "~20.2.0",
    "@angular/cli": "~20.2.2",
    "@angular/common": "~20.2.2",
    "@angular/compiler": "~20.2.2",
    "@angular/compiler-cli": "~20.2.2",
    "@angular/core": "~20.2.2",
    "@angular/fire": "~20.0.1",
    "@angular/forms": "~20.2.2",
    "@angular/material": "~20.2.14",
    "@angular/platform-browser": "~20.2.2",
    "@angular/platform-browser-dynamic": "~20.2.2",
    "@angular/router": "~20.2.2",
    "@firebase-oss/ui-angular": "^7.0.2-beta",
    "chart.js": "^4.5.1",
    "firebase": "~11.10.0",
    "ng": "^0.0.0",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "video.js": "^8.23.4",
    "videojs-youtube": "^3.0.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.2.2",
    "@angular/build": "~20.2.0",
    "@angular/cli": "~20.2.0",
    "@angular/compiler-cli": "~20.2.0",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "~4.0.0",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "1.59.1",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/video.js": "^7.3.58",
    "eslint": "^10.3.0",
    "firebase-admin": "^13.8.0",
    "jasmine-core": "~5.9.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jsdom": "^27.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "playwright": "^1.59.1",
    "playwright-ng-schematics": "^20.0.2",
    "test": "^3.3.0",
    "ts-jest": "^29.4.9",
    "typedoc": "^0.28.15",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.1.1"
  }
}
